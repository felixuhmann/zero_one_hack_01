# Copy to .env and fill in your keys (do not commit .env)
FRED_API_KEY=
SYBILION_API_KEY=

# Chat (/api/chat) — LLM via Vercel AI Gateway (OpenAI-compatible).
# Get a key at https://vercel.com/dashboard -> AI Gateway -> API Keys.
AI_GATEWAY_API_KEY=
# Optional overrides:
#   LLM_MODEL=anthropic/claude-sonnet-4.6   # any gateway "<provider>/<model>"
#   LLM_BASE_URL=https://ai-gateway.vercel.sh/v1
# Point LLM_BASE_URL at a self-hosted / Leonardo vLLM endpoint to stay sovereign.
